library(shiny)
library(ggplot2)
library(knitr)
library(dplyr)
set.seed(2026)
stasiun_list <- c("EV-01 Jakarta Pusat", "EV-02 Jakarta Selatan", "EV-03 Depok Margonda",
"EV-04 Serpong Tangerang", "EV-05 Bandung Dago", "EV-06 Surabaya Barat")
# Bangkitkan data multi-bulan (Mei, Juni, Juli) secara aman
data_base <- data.frame(
ID_Transaksi = 1001:1300,
Tanggal = seq(as.Date("2026-05-01"), as.Date("2026-07-04"), length.out = 300),
Stasiun = sample(stasiun_list, 300, replace = TRUE),
Konsumsi_kWh = runif(300, min = 20, max = 65),
Tarif_per_kWh = 2500,
Jam_Aktif = runif(300, min = 1.5, max = 6)
)
data_base$Pendapatan_Rp <- data_base$Konsumsi_kWh * data_base$Tarif_per_kWh
# Ambil nama bulan bahasa Inggris bawaan sistem R agar stabil
data_base$Bulan_Nama <- format(data_base$Tanggal, "%B")
# Chunk 2: logika_reaktif
# Mengunci filter data reaktif berdasarkan dropdown bulan di atas
data_aktif <- reactive({
subset(data_base, Bulan_Nama == input$pilih_bulan)
})
shinyApp(ui, server)
library(shiny)
library(shiny)
library(ggplot2)
library(dplyr)
# 1. GENERATE DATABASE MASTER (6 STASIUN)
set.seed(2026)
stasiun_list <- c("EV-01 Jakarta Pusat", "EV-02 Jakarta Selatan", "EV-03 Depok Margonda",
"EV-04 Serpong Tangerang", "EV-05 Bandung Dago", "EV-06 Surabaya Barat")
data_base <- data.frame(
ID_Transaksi = 1001:1300,
Tanggal = seq(as.Date("2026-05-01"), as.Date("2026-07-04"), length.out = 300),
Stasiun = sample(stasiun_list, 300, replace = TRUE),
Konsumsi_kWh = runif(300, min = 20, max = 65),
Tarif_per_kWh = 2500,
Jam_Aktif = runif(300, min = 1.5, max = 6)
)
data_base$Pendapatan_Rp <- data_base$Konsumsi_kWh * data_base$Tarif_per_kWh
data_base$Bulan_Nama <- format(data_base$Tanggal, "%B")
# 2. FRONTEND INTERFACE (UI) WITH PREMIUM CSS CARD
ui <- fluidPage(
tags$style(HTML("
body { background-color: #f8fafc; font-family: 'Segoe UI', sans-serif; padding: 30px; }
.header-box { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; padding: 35px; border-radius: 12px; margin-bottom: 25px; }
.card-box { background: white; border-radius: 12px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; margin-bottom: 25px; }
.card-box h3 { font-size: 18px; font-weight: 600; color: #0f172a; margin-top: 0; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; margin-bottom: 20px; }
.kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.kpi-card { background: #f8fafc; border-top: 4px solid #10b981; padding: 15px; border-radius: 6px; }
.kpi-card.prediksi { border-top-color: #3b82f6; }
.kpi-card strong { display: block; font-size: 11px; color: #64748b; text-transform: uppercase; margin-bottom: 5px; }
.kpi-card span { font-size: 18px; font-weight: 700; color: #0f172a; }
")),
# Header Jumbotron
div(class = "header-box",
h1("PT Green Charge Indonesia", style = "margin:0; font-weight:700; font-size:30px;"),
p("Dashboard Eksekutif Analitik Operasional Stasiun EV", style = "margin:5px 0 0 0; color:#cbd5e1;"),
p("Otorisasi: Operator Stasiun (24611052-sho) | Tanggal: 2026-07-04", style = "margin:15px 0 0 0; font-size:12px; color:#94a3b8;")
),
# Filter Kontrol
div(class = "card-box",
selectInput("pilih_bulan", "Silahkan Pilih Bulan Operasional:", choices = unique(data_base$Bulan_Nama), width = "350px")
),
# Section 1: KPI Grid
div(class = "card-box",
h3("1. Indikator Kinerja Utama (KPI Status)"),
uiOutput("kpi_render")
),
# Section 2 & 3: Tabel & Grafik Berdampingan
fluidRow(
column(6, div(class = "card-box", h3("2. Rincian Finansial Stasiun"), tableOutput("tabel_render"))),
column(6, div(class = "card-box", h3("3. Visualisasi Tren Konsumsi Daya"), plotOutput("grafik_render", height = "280px")))
)
)
# 3. BACKEND COMPUTATION (SERVER)
server <- function(input, output, session) {
data_aktif <- reactive({
data_base %>% filter(Bulan_Nama == input$pilih_bulan)
})
# Menghitung dan Membentuk Komponen UI KPI secara Dinamis
output$kpi_render <- renderUI({
df <- data_aktif()
total_kwh <- round(sum(df$Konsumsi_kWh), 2)
total_rp <- format(round(sum(df$Pendapatan_Rp), 0), big.mark = ".")
utilitas <- round(mean(df$Jam_Aktif), 2)
prediksi <- round(total_kwh * 1.05, 2)
div(class = "kpi-grid",
div(class = "kpi-card", tags$strong("Total Konsumsi"), tags$span(paste(total_kwh, "kWh"))),
div(class = "kpi-card", tags$strong("Total Pendapatan"), tags$span(paste("Rp", total_rp))),
div(class = "kpi-card", tags$strong("Rata-rata Utilitas"), tags$span(paste(utilitas, "Jam/Sesi"))),
div(class = "kpi-card prediksi", tags$strong("Prediksi Bulan Depan"), tags$span(paste(prediksi, "kWh")))
)
})
# Membuat Tabel Agregasi
output$tabel_render <- renderTable({
data_aktif() %>%
group_by(Stasiun) %>%
summarise(
`Total Daya (kWh)` = round(sum(Konsumsi_kWh), 2),
`Total Pendapatan` = sum(Pendapatan_Rp)
) %>%
mutate(`Total Pendapatan` = paste("Rp", format(round(`Total Pendapatan`, 0), big.mark = "."))) %>%
rename(`Nama Stasiun Pengisian` = Stasiun)
}, width = "100%", striped = FALSE, hover = TRUE)
# Membuat Grafik Batang GGPlot2
output$grafik_render <- renderPlot({
ggplot(data_aktif(), aes(x = Stasiun, y = Konsumsi_kWh, fill = Stasiun)) +
geom_bar(stat = "identity", width = 0.5, alpha = 0.9) +
theme_minimal() +
labs(x = NULL, y = "Daya (kWh)") +
scale_fill_manual(values = c("#10b981", "#0f172a", "#3b82f6", "#f59e0b", "#ef4444", "#8b5cf6")) +
theme(legend.position = "none", axis.text.x = element_text(angle = 20, hjust = 1))
})
}
shinyApp(ui, server)
