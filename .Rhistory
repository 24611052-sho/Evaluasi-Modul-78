library(shiny)
library(ggplot2)
library(knitr)
library(dplyr)
# 1. DATABASE MASTER
set.seed(2026)
stasiun_list <- c("EV-01 Jakarta Pusat", "EV-02 Jakarta Selatan", "EV-03 Depok Margonda",
"EV-04 Serpong Tangerang", "EV-05 Bandung Dago", "EV-06 Surabaya Barat")
data_base <- data.frame(
ID_Transaksi = 1001:1300,
Tanggal = seq(as.Date("2026-05-01"), as.Date("2026-07-04"), length.out = 300),
Stasiun = sample(stasiun_list, 300, replace = TRUE),
Konsumsi_kWh = runif(300, min = 20, max = 65),
Tarif_per_kWh = 2500,
Jam_Aktif = runif(300, min = 1.5, max = 6)
)
data_base$Pendapatan_Rp <- data_base$Konsumsi_kWh * data_base$Tarif_per_kWh
data_base$Bulan_Nama <- format(data_base$Tanggal, "%B")
# 2. EMBED PREMIUM DESIGN (Memasukkan CSS Aplikasi ke dalam R Markdown)
fluidPage(
tags$style(HTML("
body { background-color: #f8fafc; font-family: 'Segoe UI', sans-serif; margin: 0 auto; max-width: 1200px; padding-top: 10px; }
.header-box { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; padding: 35px; border-radius: 12px; margin-bottom: 25px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
.card-box { background: white; border-radius: 12px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; margin-bottom: 25px; }
.card-box h3 { font-size: 18px; font-weight: 600; color: #0f172a; margin-top: 0; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; margin-bottom: 20px; }
.kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.kpi-card { background: #f8fafc; border-top: 4px solid #10b981; padding: 15px; border-radius: 6px; box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.02); }
.kpi-card.prediksi { border-top-color: #3b82f6; }
.kpi-card strong { display: block; font-size: 11px; color: #64748b; text-transform: uppercase; margin-bottom: 5px; }
.kpi-card span { font-size: 18px; font-weight: 700; color: #0f172a; }
table { width: 100% !important; border-collapse: collapse !important; }
th { background-color: #0f172a !important; color: white !important; font-weight: 600 !important; padding: 12px !important; font-size: 13px; text-transform: uppercase; border: none !important; }
td { padding: 12px !important; border-bottom: 1px solid #e2e8f0 !important; font-size: 14px; color: #334155; }
tr:hover td { background-color: #f8fafc; }
")),
# Header Jumbotron Premium
div(class = "header-box",
h1("PT Green Charge Indonesia", style = "margin:0; font-weight:700; font-size:30px;"),
p("Dashboard Eksekutif Analitik Operasional Stasiun EV", style = "margin:5px 0 0 0; color:#cbd5e1;"),
p("Otorisasi: Operator Stasiun (24611052-sho) | Tanggal Cetak: 2026-07-04", style = "margin:15px 0 0 0; font-size:12px; color:#94a3b8;")
),
# Kontrol Panel Input Bulan
div(class = "card-box",
selectInput("pilih_bulan", "Silahkan Pilih Bulan Operasional:", choices = unique(data_base$Bulan_Nama), width = "350px")
),
# Render Ringkasan KPI Card
div(class = "card-box",
h3("1. Indikator Kinerja Utama (KPI Status)"),
uiOutput("kpi_render")
),
# Render Tabel dan Grafik Berdampingan
fluidRow(
column(6, div(class = "card-box", h3("2. Rincian Finansial Stasiun"), tableOutput("tabel_render"))),
column(6, div(class = "card-box", h3("3. Visualisasi Tren Konsumsi Daya"), plotOutput("grafik_render", height = "300px")))
)
)
# --- LOGIKA REAKTIF BACKEND ---
data_aktif <- reactive({
data_base %>% filter(Bulan_Nama == input$pilih_bulan)
})
output$kpi_render <- renderUI({
df <- data_aktif()
total_kwh <- round(sum(df$Konsumsi_kWh), 2)
total_rp <- format(round(sum(df$Pendapatan_Rp), 0), big.mark = ".")
utilitas <- round(mean(df$Jam_Aktif), 2)
prediksi <- round(total_kwh * 1.05, 2)
div(class = "kpi-grid",
div(class = "kpi-card", tags$strong("Total Konsumsi"), tags$span(paste(total_kwh, "kWh"))),
div(class = "kpi-card", tags$strong("Total Pendapatan"), tags$span(paste("Rp", total_rp))),
div(class = "kpi-card", tags$strong("Rata-rata Utilitas"), tags$span(paste(utilitas, "Jam/Sesi"))),
div(class = "kpi-card prediksi", tags$strong("Prediksi Bulan Depan"), tags$span(paste(prediksi, "kWh")))
)
})
# Menutup semua warning dan log agar tidak merusak visual dashboard
knitr::opts_chunk$set(warning = FALSE, message = FALSE, echo = FALSE)
library(shiny)
library(ggplot2)
library(knitr)
library(dplyr)
# 1. DATABASE MASTER
set.seed(2026)
stasiun_list <- c("EV-01 Jakarta Pusat", "EV-02 Jakarta Selatan", "EV-03 Depok Margonda",
"EV-04 Serpong Tangerang", "EV-05 Bandung Dago", "EV-06 Surabaya Barat")
data_base <- data.frame(
ID_Transaksi = 1001:1300,
Tanggal = seq(as.Date("2026-05-01"), as.Date("2026-07-04"), length.out = 300),
Stasiun = sample(stasiun_list, 300, replace = TRUE),
Konsumsi_kWh = runif(300, min = 20, max = 65),
Tarif_per_kWh = 2500,
Jam_Aktif = runif(300, min = 1.5, max = 6)
)
data_base$Pendapatan_Rp <- data_base$Konsumsi_kWh * data_base$Tarif_per_kWh
data_base$Bulan_Nama <- format(data_base$Tanggal, "%B")
# 2. EMBED PREMIUM DESIGN (Memasukkan CSS Aplikasi ke dalam R Markdown)
fluidPage(
tags$style(HTML("
body { background-color: #f8fafc; font-family: 'Segoe UI', sans-serif; margin: 0 auto; max-width: 1200px; padding-top: 10px; }
.header-box { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white; padding: 35px; border-radius: 12px; margin-bottom: 25px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
.card-box { background: white; border-radius: 12px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; margin-bottom: 25px; }
.card-box h3 { font-size: 18px; font-weight: 600; color: #0f172a; margin-top: 0; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; margin-bottom: 20px; }
.kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.kpi-card { background: #f8fafc; border-top: 4px solid #10b981; padding: 15px; border-radius: 6px; box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.02); }
.kpi-card.prediksi { border-top-color: #3b82f6; }
.kpi-card strong { display: block; font-size: 11px; color: #64748b; text-transform: uppercase; margin-bottom: 5px; }
.kpi-card span { font-size: 18px; font-weight: 700; color: #0f172a; }
table { width: 100% !important; border-collapse: collapse !important; }
th { background-color: #0f172a !important; color: white !important; font-weight: 600 !important; padding: 12px !important; font-size: 13px; text-transform: uppercase; border: none !important; }
td { padding: 12px !important; border-bottom: 1px solid #e2e8f0 !important; font-size: 14px; color: #334155; }
tr:hover td { background-color: #f8fafc; }
")),
# Header Jumbotron Premium
div(class = "header-box",
h1("PT Green Charge Indonesia", style = "margin:0; font-weight:700; font-size:30px;"),
p("Dashboard Eksekutif Analitik Operasional Stasiun EV", style = "margin:5px 0 0 0; color:#cbd5e1;"),
p("Otorisasi: Operator Stasiun (24611052-sho) | Tanggal Cetak: 2026-07-04", style = "margin:15px 0 0 0; font-size:12px; color:#94a3b8;")
),
# Kontrol Panel Input Bulan
div(class = "card-box",
selectInput("pilih_bulan", "Silahkan Pilih Bulan Operasional:", choices = unique(data_base$Bulan_Nama), width = "350px")
),
# Render Ringkasan KPI Card
div(class = "card-box",
h3("1. Indikator Kinerja Utama (KPI Status)"),
uiOutput("kpi_render")
),
# Render Tabel dan Grafik Berdampingan
fluidRow(
column(6, div(class = "card-box", h3("2. Rincian Finansial Stasiun"), tableOutput("tabel_render"))),
column(6, div(class = "card-box", h3("3. Visualisasi Tren Konsumsi Daya"), plotOutput("grafik_render", height = "300px")))
)
)
# --- LOGIKA REAKTIF BACKEND ---
data_aktif <- reactive({
data_base %>% filter(Bulan_Nama == input$pilih_bulan)
})
output$kpi_render <- renderUI({
df <- data_aktif()
total_kwh <- round(sum(df$Konsumsi_kWh), 2)
total_rp <- format(round(sum(df$Pendapatan_Rp), 0), big.mark = ".")
utilitas <- round(mean(df$Jam_Aktif), 2)
prediksi <- round(total_kwh * 1.05, 2)
div(class = "kpi-grid",
div(class = "kpi-card", tags$strong("Total Konsumsi"), tags$span(paste(total_kwh, "kWh"))),
div(class = "kpi-card", tags$strong("Total Pendapatan"), tags$span(paste("Rp", total_rp))),
div(class = "kpi-card", tags$strong("Rata-rata Utilitas"), tags$span(paste(utilitas, "Jam/Sesi"))),
div(class = "kpi-card prediksi", tags$strong("Prediksi Bulan Depan"), tags$span(paste(prediksi, "kWh")))
)
})
