#' @export
hitung_kpi_summary <- function(df) {
if (nrow(df) == 0) {
return(list(total_kwh = 0, utilitas = 0, total_rp = "0", prediksi = 0))
}
# Variabel disamakan semua menggunakan total_kwh agar tidak bentrok
total_kwh <- round(sum(df$Konsumsi_kWh), 2)
utilitas  <- round(hitung_utilitas_stasiun(df), 2)
total_rp  <- format_neraca_keuangan(sum(df$Pendapatan_Rp))
prediksi  <- round(prediksi_kebutuhan_daya(total_kwh, 0.05), 2)
return(list(
total_kwh = total_kwh,
utilitas  = utilitas,
total_rp  = total_rp,
prediksi  = prediksi
))
}
