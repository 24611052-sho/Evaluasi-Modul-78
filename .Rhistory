# Chunk 1: setup_data
library(ggplot2)
library(knitr)
set.seed(2026)
# DAFTAR STASIUN DIPERBANYAK MENJADI 6 TITIK UTAMA
stasiun_list <- c("EV-01 Jakarta Pusat", "EV-02 Jakarta Selatan", "EV-03 Depok Margonda",
"EV-04 Serpong Tangerang", "EV-05 Bandung Dago", "EV-06 Surabaya Barat")
data_mentah <- data.frame(
ID_Transaksi = 1001:1150,
Tanggal = seq(as.Date("2026-06-01"), as.Date("2026-07-04"), length.out = 150),
Stasiun = sample(stasiun_list, 150, replace = TRUE),
Konsumsi_kWh = runif(150, min = 20, max = 65),
Tarif_per_kWh = 2500,
Jam_Aktif = runif(150, min = 1.5, max = 6)
)
data_mentah$Pendapatan_Rp <- data_mentah$Konsumsi_kWh * data_mentah$Tarif_per_kWh
data_mentah$Bulan_Nama <- format(data_mentah$Tanggal, "%B")
data_laporan <- subset(data_mentah, Bulan_Nama == "July")
# Chunk 2: setup_data
tabel_ringkasan <- aggregate(
cbind(Total_Energi_kWh = data_laporan$Konsumsi_kWh, Total_Pendapatan_Rp = data_laporan$Pendapatan_Rp),
by = list(Lokasi_Stasiun = data_laporan$Stasiun),
FUN = sum
)
