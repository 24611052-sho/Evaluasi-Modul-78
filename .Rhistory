library(ggplot2)
library(knitr)
set.seed(2026)
stasiun_list <- c("EV-01 Jakarta Pusat", "EV-02 Jakarta Selatan", "EV-03 Depok Margonda",
"EV-04 Serpong Tangerang", "EV-05 Bandung Dago", "EV-06 Surabaya Barat")
data_mentah <- data.frame(
ID_Transaksi = 1001:1150,
# Kita kunci tanggalnya murni di bulan Juli 2026 agar datanya pasti ada
Tanggal = seq(as.Date("2026-07-01"), as.Date("2026-07-04"), length.out = 150),
Stasiun = sample(stasiun_list, 150, replace = TRUE),
Konsumsi_kWh = runif(150, min = 20, max = 65),
Tarif_per_kWh = 2500,
Jam_Aktif = runif(150, min = 1.5, max = 6)
)
data_mentah$Pendapatan_Rp <- data_mentah$Konsumsi_kWh * data_mentah$Tarif_per_kWh
data_mentah$Bulan_Nama <- format(data_mentah$Tanggal, "%B")
# SOLUSI SAKTI: Kita langsung pakai semua datanya tanpa filter teks "July" atau "Juli"
data_laporan <- data_mentah
Bulan_Terbaru <- data_laporan$Bulan_Nama[1]
tabel_ringkasan <- aggregate(
cbind(Total_Energi_kWh = data_laporan$Konsumsi_kWh, Total_Pendapatan_Rp = data_laporan$Pendapatan_Rp),
by = list(Lokasi_Stasiun = data_laporan$Stasiun),
FUN = sum
)
tabel_ringkasan$Total_Energi_kWh <- round(tabel_ringkasan$Total_Energi_kWh, 2)
tabel_ringkasan$Total_Pendapatan_Rp <- paste("Rp", format(round(tabel_ringkasan$Total_Pendapatan_Rp, 0), big.mark = "."))
knitr::kable(tabel_ringkasan, align = c('l', 'c', 'c'))
ggplot(data_laporan, aes(x = Stasiun, y = Konsumsi_kWh, fill = Stasiun)) +
geom_bar(stat = "identity", width = 0.5, alpha = 0.9) +
theme_minimal(base_size = 11) +
labs(x = NULL, y = "Daya Tersalurkan (kWh)") +
scale_fill_manual(values = c("#10b981", "#0f172a", "#3b82f6", "#f59e0b", "#ef4444", "#8b5cf6")) +
theme(
legend.position = "none",
panel.grid.major.x = element_blank(),
panel.grid.minor = element_blank(),
axis.text.x = element_text(angle = 15, hjust = 1, color = "#475569")
)
