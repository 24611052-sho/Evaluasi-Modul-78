devtools::document()
#' @export
hitung_kpi_summary <- function(df) {
if (nrow(df) == 0) {
return(list(total_kwh = 0, utilitas = 0, total_rp = "0", prediksi = 0))
}
# Memanggil 3 fungsi internal package yang sudah kita buat sebelumnya
t_kwh  <- round(sum(df$Konsumsi_kWh), 2)
util   <- round(hitung_utilitas_stasiun(df), 2)
omzet  <- format_neraca_keuangan(sum(df$Pendapatan_Rp))
pred   <- round(prediksi_kebutuhan_daya(t_kwh, 0.05), 2)
# Kembalikan dalam bentuk list ringkas
return(list(
total_kwh = t_kwh,
utilitas  = util,
total_rp  = omzet,
prediksi  = pred
))
}
